apps/*/out/

# production
/build
apps/backend/bin
apps/backend/dist
apps/backend/api

# misc
.DS_Store
.idea
.vscode
*.pem
*.log
ops/platform/forgejo/data/
ops/platform/forgejo/postgres/
ops/platform/forgejo/runner/
ops/platform/forgejo/caddy/

