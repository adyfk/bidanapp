{
  "name": "bidanapp-monorepo",
  "version": "0.0.0-private",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.12.0",
    "npm": ">=11.6.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "biome:check": "biome ci .",
    "biome:write": "biome check --write .",
    "branch:lint": "node ./scripts/ci/check-branch-name.cjs",
    "changeset": "changeset",
    "changeset:check": "node ./scripts/ci/check-changeset.cjs",
    "changeset:status": "changeset status --verbose",
    "changeset:version": "changeset version",
    "ci:check": "npm run contract:generate && npm run generated:check && npm run boundary:check && npm run ui:guard && npm run lint && npm run typecheck && npm run test && npm run build",
    "commit": "commit",
    "dev": "node ./scripts/dev/run.cjs",
    "dev:new": "npm run dev",
    "dev:doctor": "node ./scripts/dev/doctor.cjs",
    "dev:db:reset": "node ./scripts/dev/reset-db.cjs",
    "dev:setup": "node ./scripts/dev/setup.cjs",
    "dev:smoke": "npm run clear:auth-rate-limit --workspace @marketplace/backend && node ./scripts/dev/smoke.cjs",
    "dev:e2e": "node -e \"process.env.NEXT_WEBPACK='1'; require('./scripts/dev/run.cjs')\"",
    "e2e": "npm run clear:auth-rate-limit --workspace @marketplace/backend && playwright test",
    "e2e:headed": "npm run clear:auth-rate-limit --workspace @marketplace/backend && playwright test --headed",
    "e2e:install": "playwright install chromium",
    "e2e:journey": "node ./scripts/journey/run-e2e.cjs",
    "e2e:smoke": "npm run clear:auth-rate-limit --workspace @marketplace/backend && playwright test tests/e2e/auth-and-sso.spec.ts tests/e2e/orders-and-payments.spec.ts tests/e2e/professional-and-admin.spec.ts",
    "env:sync": "node ./scripts/dev/env-sync.cjs",
    "dev:admin": "npm run dev --workspace @marketplace/admin",
    "dev:admin:webpack": "npm run dev:webpack --workspace @marketplace/admin",
    "dev:bidan": "npm run dev --workspace @marketplace/bidan",
    "dev:bidan:webpack": "npm run dev:webpack --workspace @marketplace/bidan",
    "dev:backend": "npm run dev --workspace @marketplace/backend",
    "dev:seed:bidan": "npm run seed:bidan-demo --workspace @marketplace/backend",
    "format": "biome format --write .",
    "generated:check": "node ./scripts/ci/check-generated-clean.cjs",
    "build": "turbo run build",
    "lint": "npm run biome:check && turbo run lint --filter=@marketplace/backend",
    "boundary:check": "node ./scripts/ci/check-runtime-boundaries.cjs",
    "ui:guard": "node ./scripts/ci/check-ui-hardcoding.cjs",
    "prepare": "node ./scripts/ci/install-hooks.cjs",
    "pr:body:lint": "node ./scripts/ci/check-pr-body.cjs",
    "pr:title:lint": "node ./scripts/ci/lint-pr-title.cjs",
    "release:ci": "node ./scripts/release/run-changeset-release.cjs",
    "release:dry-run": "node ./scripts/release/run-changeset-release.cjs --dry-run",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck --concurrency=1",
    "contract:generate": "npm run generate --workspace @marketplace/sdk",
    "check": "npm run boundary:check && npm run ui:guard && npm run lint && npm run typecheck && npm run test && npm run build",
    "doctor": "node --version && npm --version && go version",
    "clean": "rm -rf .turbo apps/*/.turbo apps/*/.next apps/backend/bin apps/backend/api",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "platform:scaffold": "node ./scripts/platform/scaffold.cjs",
    "journey:clean": "node ./scripts/journey/clean.cjs",
    "journey:gallery": "node ./scripts/journey/generate-screenshot-gallery.cjs",
    "journey:open": "node ./scripts/journey/open.cjs",
    "start:admin": "npm run start --workspace @marketplace/admin",
    "start:bidan": "npm run start --workspace @marketplace/bidan",
    "start:backend": "npm run start --workspace @marketplace/backend"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/prompt-cli": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "lefthook": "^2.1.4",
    "turbo": "^2.5.6"
  }
}
