{
  "name": "bidanapp-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.12.0",
    "npm": ">=11.6.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:frontend": "npm run dev --workspace @bidanapp/frontend",
    "dev:backend": "npm run dev --workspace @bidanapp/backend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "contract:generate": "npm run generate --workspace @bidanapp/sdk",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "doctor": "node --version && npm --version && go version",
    "clean": "rm -rf .turbo apps/*/.turbo apps/frontend/.next apps/frontend/out apps/backend/bin apps/backend/api",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "start:frontend": "npm run start --workspace @bidanapp/frontend",
    "start:backend": "npm run start --workspace @bidanapp/backend"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
