{
  "name": "@marketplace/ui",
  "version": "0.0.0-private",
  "private": true,
  "type": "module",
  "main": "./src/index.tsx",
  "types": "./src/index.tsx",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "default": "./src/index.tsx"
    },
    "./foundations": {
      "types": "./src/foundations.ts",
      "default": "./src/foundations.ts"
    },
    "./marketplace": {
      "types": "./src/marketplace.tsx",
      "default": "./src/marketplace.tsx"
    },
    "./marketplace-lite": {
      "types": "./src/marketplace-lite.tsx",
      "default": "./src/marketplace-lite.tsx"
    },
    "./motion": {
      "types": "./src/motion.tsx",
      "default": "./src/motion.tsx"
    },
    "./patterns": {
      "types": "./src/patterns.tsx",
      "default": "./src/patterns.tsx"
    },
    "./primitives": {
      "types": "./src/primitives.tsx",
      "default": "./src/primitives.tsx"
    },
    "./system.css": "./src/system.css"
  },
  "sideEffects": [
    "./src/system.css"
  ],
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && npm run typecheck",
    "lint": "biome ci .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "framer-motion": "^12.38.0"
  }
}
