{
  "name": "@bidanapp/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "npm run generate && npm run typecheck",
    "generate": "npm run export:spec && npm run generate:types",
    "export:spec": "cd ../../apps/backend && go run ./cmd/openapi-export -json ../../packages/sdk/openapi.json",
    "generate:types": "openapi-typescript ./openapi.json -o ./src/generated/types.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
