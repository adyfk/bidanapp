{
  "name": "@marketplace/marketplace-core",
  "version": "0.0.0-private",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./directory": {
      "types": "./src/directory.ts",
      "default": "./src/directory.ts"
    },
    "./formatters": {
      "types": "./src/formatters.ts",
      "default": "./src/formatters.ts"
    },
    "./notifications": {
      "types": "./src/notifications.ts",
      "default": "./src/notifications.ts"
    },
    "./orders": {
      "types": "./src/orders.ts",
      "default": "./src/orders.ts"
    },
    "./professional": {
      "types": "./src/professional.ts",
      "default": "./src/professional.ts"
    },
    "./support": {
      "types": "./src/support.ts",
      "default": "./src/support.ts"
    },
    "./viewer-auth": {
      "types": "./src/viewer-auth.ts",
      "default": "./src/viewer-auth.ts"
    }
  },
  "dependencies": {
    "@marketplace/platform-config": "0.0.0-private",
    "@marketplace/sdk": "0.0.0-private"
  },
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && npm run typecheck",
    "lint": "biome ci .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
