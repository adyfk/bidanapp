{
  "name": "@marketplace/web",
  "version": "0.0.0-private",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./local-host-redirect": {
      "types": "./src/lib/local-host-redirect.ts",
      "default": "./src/lib/local-host-redirect.ts"
    }
  },
  "dependencies": {
    "@marketplace/marketplace-core": "0.0.0-private",
    "@marketplace/platform-config": "0.0.0-private",
    "@marketplace/ui": "0.0.0-private",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.552.0",
    "next": "16.1.6",
    "react": "19.2.4"
  },
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && npm run typecheck",
    "lint": "biome ci .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.2.2",
    "typescript": "^5.9.3"
