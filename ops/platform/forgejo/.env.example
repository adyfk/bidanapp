# Public access
# Default ini sengaja local-friendly supaya bisa langsung dicopy lalu dijalankan.
FORGEJO_DOMAIN=localhost
FORGEJO_ROOT_URL=https://localhost:8443/
FORGEJO_PUBLIC_HTTP_PORT=8088
FORGEJO_PUBLIC_HTTPS_PORT=8443

# Forgejo database
FORGEJO_DB_NAME=forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=change-me

# Service behavior
FORGEJO_DISABLE_REGISTRATION=true

# One-time bootstrap values for the manual admin creation command in docs.
FORGEJO_ADMIN_USERNAME=admin
FORGEJO_ADMIN_PASSWORD=change-me-now
FORGEJO_ADMIN_EMAIL=admin@localhost

# Runner registration defaults used in the manual registration command in docs.
FORGEJO_RUNNER_NAME=bidanapp-runner
FORGEJO_RUNNER_LABELS=docker,deploy
