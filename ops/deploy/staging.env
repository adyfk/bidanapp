# Copy to ops/deploy/staging.env lalu build image lokal dengan:
# sh ./scripts/deploy/build-images.sh ops/deploy/staging.env
# lalu deploy dengan:
# sh ./scripts/deploy/deploy.sh staging ops/deploy/staging.env

COMPOSE_PROJECT_NAME=bidanapp-staging
APP_ENV=staging
APP_VERSION=main-local
BACKEND_IMAGE=bidanapp-backend:local
FRONTEND_IMAGE=bidanapp-frontend:local
BACKEND_PORT=18080
FRONTEND_PORT=13000
PUBLIC_SITE_URL=http://localhost:13000
PUBLIC_API_BASE_URL=http://localhost:18080/api/v1
POSTGRES_DB=bidanapp_staging
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://postgres:change-me@postgres:5432/bidanapp_staging?sslmode=disable
REDIS_URL=redis://redis:6379
CORS_ALLOWED_ORIGINS=http://localhost:13000
LOG_LEVEL=info
LOG_FORMAT=json
