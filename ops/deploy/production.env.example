# Copy to ops/deploy/production.env, replace all placeholder values, lalu validasi dengan:
# node ./scripts/deploy/check-env.mjs ops/deploy/production.env
# build image:
# sh ./scripts/deploy/build-images.sh ops/deploy/production.env
# deploy:
# sh ./scripts/deploy/deploy.sh production ops/deploy/production.env

COMPOSE_PROJECT_NAME=bidanapp-production
APP_ENV=production
APP_VERSION=2026.03.23
BACKEND_IMAGE=registry.example.com/bidanapp/backend:2026.03.23
FRONTEND_IMAGE=registry.example.com/bidanapp/frontend:2026.03.23
BACKEND_PORT=28080
FRONTEND_PORT=23000
PUBLIC_SITE_URL=https://app.bidanapp.id
PUBLIC_API_BASE_URL=https://api.bidanapp.id/api/v1
NEXT_PUBLIC_ADMIN_CONSOLE_ENABLED=true
NEXT_PUBLIC_ADMIN_STUDIO_ENABLED=false
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=REPLACE_WITH_PRODUCTION_WEB_PUSH_PUBLIC_KEY
POSTGRES_DB=bidanapp_production
POSTGRES_PORT=35432
POSTGRES_USER=bidanapp
POSTGRES_PASSWORD=REPLACE_WITH_PRODUCTION_DB_PASSWORD
DATABASE_URL=postgres://bidanapp:REPLACE_WITH_PRODUCTION_DB_PASSWORD@postgres:5432/bidanapp_production?sslmode=disable
REDIS_URL=redis://redis:6379/0
CORS_ALLOWED_ORIGINS=https://app.bidanapp.id
AUTH_COOKIE_DOMAIN=.bidanapp.id
AUTH_COOKIE_PATH=/api/v1
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
ADMIN_AUTH_COOKIE_NAME=bidanapp_admin_session
CUSTOMER_AUTH_COOKIE_NAME=bidanapp_customer_session
PROFESSIONAL_AUTH_COOKIE_NAME=bidanapp_professional_session
AUTH_RATE_LIMIT_WINDOW=5m
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
ADMIN_AUTH_SESSION_TTL=24h
CUSTOMER_AUTH_SESSION_TTL=24h
PROFESSIONAL_AUTH_SESSION_TTL=24h
PAYMENT_PROVIDER=xendit
PAYMENT_CURRENCY=IDR
XENDIT_SECRET_KEY=REPLACE_WITH_PRODUCTION_XENDIT_SECRET_KEY
XENDIT_WEBHOOK_TOKEN=REPLACE_WITH_PRODUCTION_XENDIT_WEBHOOK_TOKEN
ADMIN_CONSOLE_CREDENTIALS_JSON='[{"adminId":"adm-01","email":"support@bidanapp.id","passwordHash":"REPLACE_WITH_BCRYPT_HASH_SUPPORT","focusArea":"support"},{"adminId":"adm-02","email":"reviews@bidanapp.id","passwordHash":"REPLACE_WITH_BCRYPT_HASH_REVIEWS","focusArea":"reviews"},{"adminId":"adm-03","email":"ops@bidanapp.id","passwordHash":"REPLACE_WITH_BCRYPT_HASH_OPS","focusArea":"ops"},{"adminId":"adm-04","email":"catalog@bidanapp.id","passwordHash":"REPLACE_WITH_BCRYPT_HASH_CATALOG","focusArea":"catalog"}]'
WEB_PUSH_SUBJECT=mailto:alerts@bidanapp.id
WEB_PUSH_PUBLIC_KEY=REPLACE_WITH_PRODUCTION_WEB_PUSH_PUBLIC_KEY
WEB_PUSH_PRIVATE_KEY=REPLACE_WITH_PRODUCTION_WEB_PUSH_PRIVATE_KEY
LOG_LEVEL=info
LOG_FORMAT=json
