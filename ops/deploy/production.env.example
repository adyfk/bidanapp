# Copy to ops/deploy/production.env lalu build image lokal dengan:
# sh ./scripts/deploy/build-images.sh ops/deploy/production.env
# lalu deploy dengan:
# sh ./scripts/deploy/deploy.sh production ops/deploy/production.env

COMPOSE_PROJECT_NAME=bidanapp-production
APP_ENV=production
APP_VERSION=v0.1.0-local
BACKEND_IMAGE=bidanapp-backend:local
FRONTEND_IMAGE=bidanapp-frontend:local
BACKEND_PORT=28080
FRONTEND_PORT=23000
PUBLIC_SITE_URL=http://localhost:23000
PUBLIC_API_BASE_URL=http://localhost:28080/api/v1
POSTGRES_DB=bidanapp_production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://postgres:change-me@postgres:5432/bidanapp_production?sslmode=disable
REDIS_URL=redis://redis:6379
CORS_ALLOWED_ORIGINS=http://localhost:23000
LOG_LEVEL=info
LOG_FORMAT=json
