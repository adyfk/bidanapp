# Application
APP_NAME=bidanapp-backend
APP_VERSION=dev
APP_ENV=local

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_MAX_HEADER_BYTES=1048576

# CORS
CORS_ALLOWED_ORIGINS=http://bidan.lvh.me:3002,http://admin.lvh.me:3005

# Session cookies
AUTH_COOKIE_DOMAIN=.lvh.me
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
ADMIN_AUTH_COOKIE_NAME=bidanapp_admin_session
VIEWER_AUTH_COOKIE_NAME=bidanapp_viewer_session

# Seed data
SEED_DATA_DIR=./seeddata
ASSET_STORAGE_DIR=./storage

# Infrastructure
# Required for runtime API server because mutable backend state now persists in PostgreSQL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bidanapp?sslmode=disable

# Admin auth
AUTH_RATE_LIMIT_WINDOW=5m
AUTH_RATE_LIMIT_MAX_ATTEMPTS=60
ADMIN_AUTH_SESSION_TTL=24h
VIEWER_AUTH_SESSION_TTL=24h
AUTH_CHALLENGE_CODE_TTL=10m
AUTH_CHALLENGE_MAX_ATTEMPTS=5
SMS_PROVIDER=console
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=
SMS_TWILIO_FROM_NUMBER=
ADMIN_CONSOLE_CREDENTIALS_JSON='[{"adminId":"adm-01","email":"naya@ops.bidanapp.id","passwordHash":"$2a$10$57VC8wMLOeqZ0YS.faDxZ.KzmBSQVtsPq6tkkPgs/jXGhghlWqPLy","focusArea":"support"},{"adminId":"adm-02","email":"rani@ops.bidanapp.id","passwordHash":"$2a$10$57VC8wMLOeqZ0YS.faDxZ.KzmBSQVtsPq6tkkPgs/jXGhghlWqPLy","focusArea":"reviews"},{"adminId":"adm-03","email":"dimas@ops.bidanapp.id","passwordHash":"$2a$10$57VC8wMLOeqZ0YS.faDxZ.KzmBSQVtsPq6tkkPgs/jXGhghlWqPLy","focusArea":"ops"},{"adminId":"adm-04","email":"vina@ops.bidanapp.id","passwordHash":"$2a$10$57VC8wMLOeqZ0YS.faDxZ.KzmBSQVtsPq6tkkPgs/jXGhghlWqPLy","focusArea":"catalog"}]'
REDIS_URL=redis://localhost:6379

# Payments
PAYMENT_PROVIDER=manual_test
PAYMENT_CURRENCY=IDR

# Observability
LOG_LEVEL=debug
LOG_FORMAT=text
