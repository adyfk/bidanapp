# Application
APP_NAME=bidanapp-backend
APP_VERSION=dev
APP_ENV=development

# HTTP server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_MAX_HEADER_BYTES=1048576

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Session cookies
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/api/v1
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
ADMIN_AUTH_COOKIE_NAME=bidanapp_admin_session
CUSTOMER_AUTH_COOKIE_NAME=bidanapp_customer_session
PROFESSIONAL_AUTH_COOKIE_NAME=bidanapp_professional_session

# Seed data
SEED_DATA_DIR=./seeddata

# Infrastructure
# Required for runtime API server because mutable backend state now persists in PostgreSQL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bidanapp?sslmode=disable

# Admin auth
AUTH_RATE_LIMIT_WINDOW=5m
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
ADMIN_AUTH_SESSION_TTL=24h
CUSTOMER_AUTH_SESSION_TTL=24h
PROFESSIONAL_AUTH_SESSION_TTL=24h
ADMIN_CONSOLE_CREDENTIALS_JSON='[{"adminId":"adm-01","email":"naya@ops.bidanapp.id","passwordHash":"$2a$12$VUpiMPsu6djn6JDj.a0a8OACtyvGtGninz4/ZwTsPGGQOK0CL./1C","focusArea":"support"},{"adminId":"adm-02","email":"rani@ops.bidanapp.id","passwordHash":"$2a$12$VUpiMPsu6djn6JDj.a0a8OACtyvGtGninz4/ZwTsPGGQOK0CL./1C","focusArea":"reviews"},{"adminId":"adm-03","email":"dimas@ops.bidanapp.id","passwordHash":"$2a$12$VUpiMPsu6djn6JDj.a0a8OACtyvGtGninz4/ZwTsPGGQOK0CL./1C","focusArea":"ops"},{"adminId":"adm-04","email":"vina@ops.bidanapp.id","passwordHash":"$2a$12$VUpiMPsu6djn6JDj.a0a8OACtyvGtGninz4/ZwTsPGGQOK0CL./1C","focusArea":"catalog"}]'
REDIS_URL=redis://localhost:6379

# Observability
LOG_LEVEL=debug
LOG_FORMAT=text
