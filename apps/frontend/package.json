{
  "name": "@bidanapp/frontend",
  "version": "0.0.0-private",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "i18n:audit": "node ../../scripts/i18n/audit.mjs",
    "i18n:prune": "node ../../scripts/i18n/audit.mjs --write",
    "i18n:types": "node ../../scripts/i18n/generate-message-types.mjs ./messages/en.json",
    "lint": "biome ci .",
    "test": "node --test ./tests/*.test.mjs",
    "test:e2e": "playwright test -c ./playwright.config.mjs",
    "test:e2e:headed": "playwright test -c ./playwright.config.mjs --headed",
    "test:e2e:trace": "PLAYWRIGHT_TRACE_MODE=on playwright test -c ./playwright.config.mjs",
    "test:e2e:trace:headed": "PLAYWRIGHT_TRACE_MODE=on playwright test -c ./playwright.config.mjs --headed",
    "test:e2e:evidence": "node ../../scripts/qa/reset-qa-visual-artifacts.mjs && PLAYWRIGHT_EVIDENCE=1 playwright test -c ./playwright.config.mjs",
    "manual-qa:summary:generate": "node ../../scripts/qa/generate-manual-qa-summary.mjs",
    "manual-qa:summary:open": "node ../../scripts/qa/show-manual-qa-summary.mjs",
    "trace:show": "node ../../scripts/qa/show-playwright-trace.mjs",
    "typecheck": "npm run i18n:types && tsc --noEmit"
  },
  "dependencies": {
    "@bidanapp/sdk": "0.0.0-private",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "allure-playwright": "^3.6.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
